{
  "expo": {
    "name": "Makan",
    "slug": "makan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.makan.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSFaceIDUsageDescription": "We use Face ID to securely authenticate your identity for fast payments and document access",
        "NSLocalNetworkUsageDescription": "For local network discovery and communication",
        "NSBonjourServices": [
          "_makan._tcp",
          "_makan._udp"
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults"
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICAategoryFileTimestampMetadata"
          }
        ]
      },
      "plugins": [
        [
          "expo-local-authentication",
          {
            "faceIDPermission": "We use Face ID to securely authenticate your identity for fast payments and document access"
          }
        ],
        [
          "expo-notifications",
          {
            "sounds": [
              "local_notification_sound.wav"
            ]
          }
        ],
        [
          "expo-camera",
          {
            "cameraPermission": "We need camera access to scan Civil ID QR codes during tenant onboarding",
            "microphonePermission": "We need microphone access for video calls during verification"
          }
        ]
      ]
    },
    "android": {
      "package": "com.makan.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.VIEW",
          "data": {
            "scheme": "makan-app"
          },
          "category": [
            "android.intent.category.DEFAULT",
            "android.intent.category.BROWSABLE"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1976D2"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "makan-1.0"
      }
    },
    "scheme": "makan-app",
    "owner": "makan-dev",
    "description": "Makan: Simplified rental property management with native mobile optimization",
    "sdkVersion": "51.0.0"
  }
}
